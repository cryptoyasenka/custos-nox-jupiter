# Custos Nox daemon configuration.
# Copy to `.env` and fill in. `.env` is gitignored.

# RPC endpoint (HTTPS). For the devnet demo, the public cluster works:
#   https://api.devnet.solana.com
# For production, use Helius or another commercial provider on the free tier:
#   https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
CUSTOS_RPC_URL=https://api.devnet.solana.com

# Optional WebSocket endpoint. Auto-derived from CUSTOS_RPC_URL when omitted
# (https:// -> wss://, http:// -> ws://).
# CUSTOS_WS_URL=wss://api.devnet.solana.com

# Cluster tag used for explorer links and event context: mainnet | devnet | testnet.
CUSTOS_CLUSTER=devnet

# Accounts to watch, comma-separated, each as `<programId>:<accountPubkey>`.
# Replace the placeholder with the PDA printed by `npm run smoke:create`.
CUSTOS_WATCH=SQDS4ep65T869zMMBKyuUq6aD6EgTu8psMjkvj52pCf:REPLACE_WITH_MULTISIG_PDA

# Optional webhooks. Alerts fan out to every configured sink (stdout is
# always on). Leave blank to disable. All sinks are fire-and-forget;
# one failing sink never blocks the others.
# CUSTOS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR/WEBHOOK
# CUSTOS_SLACK_WEBHOOK=https://hooks.slack.com/services/T/B/X
# CUSTOS_TELEGRAM_BOT_TOKEN=123456789:ABCDEFGhijklmnop
# CUSTOS_TELEGRAM_CHAT_ID=-1001234567890

# Optional public HTTP endpoint for the dashboard live feed. When set, the
# daemon also acts as an AlertSink that buffers the last 100 alerts and
# serves them as JSON on GET /events (plus GET /health). CORS = *.
# On Railway, set this to the value of $PORT (Railway picks the port).
# CUSTOS_HTTP_PORT=8787

# Bind address for CUSTOS_HTTP_PORT. Default 0.0.0.0 (all interfaces) so
# Railway/Fly/Docker bridge-network deployments work without extra config.
# When self-hosting behind a reverse proxy on the same host, set to
# 127.0.0.1 so /events and /health aren't reachable from other interfaces.
# CUSTOS_HTTP_HOST=0.0.0.0

# --- Jupiter route-exploit detector ---
# Optional. The guarded multisig (or any guarded wallet) that the
# Jupiter detector watches for unlimited-approval drainer patterns.
# Default falls back to the first watched account in CUSTOS_WATCH.
# CUSTOS_JUPITER_GUARDED=REPLACE_WITH_GUARDED_PUBKEY

# Poll interval in ms for the Jupiter detector's tx scan loop
# (`npm run watch:jupiter`). Default 15000.
# CUSTOS_JUPITER_POLL_MS=15000
