{
  "name": "custos-nox",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source real-time monitor for Solana multisigs and DAOs. Detects Drift-class attack chains.",
  "license": "MIT",
  "author": "cryptoyasenka",
  "homepage": "https://github.com/cryptoyasenka/custos-nox",
  "repository": {
    "type": "git",
    "url": "https://github.com/cryptoyasenka/custos-nox"
  },
  "bugs": {
    "url": "https://github.com/cryptoyasenka/custos-nox/issues"
  },
  "keywords": [
    "solana",
    "security",
    "monitoring",
    "multisig",
    "dao",
    "alerts",
    "squads",
    "spl-governance",
    "drift",
    "websocket",
    "helius"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/daemon.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fetch-fixture": "tsx scripts/fetch-fixture.ts",
    "setup:devnet": "tsx scripts/devnet-setup.ts",
    "smoke:create": "tsx scripts/devnet-create.ts",
    "smoke:weaken": "tsx scripts/devnet-weaken.ts",
    "smoke:timelock": "tsx scripts/devnet-timelock.ts",
    "smoke:nonce-plan": "tsx scripts/devnet-nonce.ts --plan",
    "smoke:nonce-init": "tsx scripts/devnet-nonce.ts --init",
    "smoke:rotate-signers": "tsx scripts/devnet-rotate-signers.ts",
    "check:null-subscribe": "tsx scripts/check-null-subscribe.ts",
    "watch:jupiter": "tsx scripts/run-jupiter.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@solana/spl-governance": "^0.3.28",
    "@solana/web3.js": "^1.95.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@sqds/multisig": "^2.1.4",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
